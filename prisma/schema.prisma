generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Console{
  id Int @id @default(autoincrement())
  name String @unique
  image String @default("no-image.png")
  releaseDate DateTime
  manufacturer String
  description String @db.Text
  games Games[]
}

model Games{
  id Int @id @default(autoincrement())
  title String @unique
  cover String @default("no-image.png")
  developer String
  releaseDate DateTime
  price Float
  genre String
  description String @db.Text

  // Relations
  console_id Int
  console Console @relation(fields: [console_id], references: [id])
}
